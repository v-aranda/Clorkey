# =============================================================================
# APLICAÇÃO
# =============================================================================
APP_NAME="PMBOK Modular"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080
ASSET_URL=
FRONTEND_URL=

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# =============================================================================
# LOGS
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# BANCO DE DADOS — PostgreSQL (container: pgsql)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=pmbok
DB_USERNAME=sail
DB_PASSWORD=password

# Porta exposta no host para acesso externo (ex: DBeaver, TablePlus)
FORWARD_DB_PORT=5433

# =============================================================================
# SESSÃO / CACHE / FILA
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=

# =============================================================================
# REDIS — container: redis
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Porta exposta no host para acesso externo
FORWARD_REDIS_PORT=6380

# =============================================================================
# E-MAIL
# =============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@pmbok.sys"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# STORAGE — MinIO S3-compatible (container: minio)
# =============================================================================
AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=pmbok-assets
AWS_URL=http://localhost:9001/pmbok-assets
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Portas expostas no host
FORWARD_MINIO_PORT=9001
FORWARD_MINIO_CONSOLE_PORT=8901

# =============================================================================
# DOCKER — Portas do container da aplicação expostas no host
# =============================================================================
APP_PORT=8080
VITE_PORT=5174

# UID/GID do usuário do host (evita problemas de permissão com bind mounts)
WWWUSER=1000
WWWGROUP=1000

# =============================================================================
# VITE HMR — Hot Module Replacement no Docker
# O host deve ser o IP/hostname do browser, não o container
# =============================================================================
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5174
VITE_HMR_PROTOCOL=ws

# =============================================================================
# FRONTEND (variáveis passadas ao Vite para o bundle)
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
